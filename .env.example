# ───────────────────────────────────────────────────────────
# TourneyCrew Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ───────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-side only — keep secret!
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Anthropic (Claude AI) ─────────────────────────────────────
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# ── Google Places API ────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs → Places API
# Used for enriching local business data near tournament venues
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ── Stripe (premium subscriptions) ───────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ── Admin ─────────────────────────────────────────────────────
# Arbitrary secret used to authenticate the /api/tips/moderate endpoint
# Generate with: openssl rand -hex 32
ADMIN_SECRET=your_random_admin_secret_here

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
